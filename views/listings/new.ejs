<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Your New Listing</title>
</head>

<body>
    <h3>Enter New Listing Details</h3>
    <form method="POST" action="/listings">
        <input name="title" placeholder="Enter Title" type="text">
        <br><br>
        <textarea placeholder="Enter Description" name="description"></textarea>
        <br><br>
        <input name="price" placeholder="Enter price" type="number">
        <br><br>
        <input name="image" placeholder="Enter Image URL/Link" type="text">
        <br><br>
        <input name="location" placeholder="Enter Location" type="text">
        <br><br>
        <input name="country" placeholder="Enter Country" type="text">
        <br><br>
        <button>Create</button>
    </form>
</body>

</html>