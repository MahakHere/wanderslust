<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderslust</title>
</head>

<body>
    <h3>All Listings</h3>
    <% for(ele of result) { %>
        <p>
            <a href="/listings/<%=ele._id%>">
                <%= ele.title %>
            </a>
            <br><br>
        </p>
        <hr>
        <% } %>
            <form method="GET" action="/listings/new">
                <button>Add New Listing</button>
            </form>
</body>

</html>